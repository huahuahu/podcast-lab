# Big media files (all sizes, any location under projects/)
projects/**/source/*.mp3
projects/**/source/*.mp4
projects/**/source/*.webm
projects/**/source/*.m4a
projects/**/source/*.wav
projects/**/source/*.mkv
projects/**/source/*.opus
projects/**/source/*.ogg
projects/**/audio/*.mp3
projects/**/audio/*.wav
projects/**/audio/*.m4a

# TTS cache 和 SF 切片：纯中间产物，能重生，不入 repo
projects/**/audio/tts_cache/
projects/**/transcript/sf_chunks/

# 日志文件
projects/**/*.log

# pyannote/diarization 中间 wav
projects/**/source/audio_16k.wav

# Hard cap: anything over ~5MB probably shouldn't be in git
# (run `find . -size +5M -not -path '*/\.git/*'` before committing)

# Model files
*.bin
*.onnx
*.gguf
*.safetensors

# Diarization intermediate data (keep text JSON, but not raw wav dumps)
**/*.wav
**/*.opus

# Python
__pycache__/
*.pyc
.venv/
venv/

# System
.DS_Store
